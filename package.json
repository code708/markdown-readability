{
	"name": "@code708/markdown-readability",
	"version": "0.0.0",
	"description": "Custom rules for markdownlint to improve readability of long markdown documents",
	"main": "index.js",
	"files": [
		"index.js",
		"src/",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"test": "node test/test-runner.js",
		"lint": "markdownlint '**/*.md' --ignore node_modules",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"push:check": "npm test && npm run lint && npm run format:check && echo '\n✅ Ready to push.\n' || { echo '\n❌ Do not push!\n'; exit 1; }",
		"pr:dry": "npm run push:check && node cicd/pull-request.js --dry-run",
		"pr:prepare": "npm run push:check && node cicd/pull-request.js --prepare",
		"pr:create": "npm run push:check && node cicd/pull-request.js --create",
		"pr:update": "npm run push:check && node cicd/pull-request.js --update"
	},
	"keywords": [
		"markdownlint",
		"markdown",
		"lint",
		"custom-rules",
		"readability"
	],
	"author": "code708",
	"license": "ISC",
	"repository": {
		"type": "git",
		"url": "https://github.com/code708/markdown-readability.git"
	},
	"bugs": {
		"url": "https://github.com/code708/markdown-readability/issues"
	},
	"homepage": "https://github.com/code708/markdown-readability#readme",
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"markdownlint": ">=0.34.0 <1.0.0"
	},
	"devDependencies": {
		"@types/node": "^18.19.130",
		"markdownlint": "^0.34.0",
		"markdownlint-cli": "^0.40.0",
		"prettier": "^3.8.2"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
